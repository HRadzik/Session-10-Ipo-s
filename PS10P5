# Global variables
total = 0.0
tax = 0.0

def compute_total(qty, price):
    global total
    total = qty * price

    global tax
    tax = total * 0.07

# Main
qty = float(input("Enter quantity: "))
price = float(input("Enter unit price: "))

compute_total(qty, price)

print("Total:", total)
print("Tax:", tax)
