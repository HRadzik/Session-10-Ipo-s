def compute_bowling(s1, s2, s3, handicap):
    avg = (s1 + s2 + s3) / 3
    avg_handicap = avg + handicap
    return avg, avg_handicap

# Main
name = input("Enter bowler last name: ")
s1 = float(input("Enter game 1 score: "))
s2 = float(input("Enter game 2 score: "))
s3 = float(input("Enter game 3 score: "))
handicap = float(input("Enter handicap: "))

avg, avg_h = compute_bowling(s1, s2, s3, handicap)

print("Name:", name)
print("Average:", avg)
print("Average with Handicap:", avg_h)
